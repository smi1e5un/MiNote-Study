<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 画板区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="16dp">

        <net.micode.notes.ui.DrawingView
            android:id="@+id/drawing_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- 工具按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- 黑色画笔 - 使用 background 颜色替代 colorFilter -->
        <ImageButton
            android:id="@+id/btn_color_black"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#000000"
            android:src="@android:drawable/presence_online"
            android:contentDescription="黑色" />

        <!-- 红色画笔 -->
        <ImageButton
            android:id="@+id/btn_color_red"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#FF0000"
            android:src="@android:drawable/presence_online"
            android:contentDescription="红色" />

        <!-- 蓝色画笔 -->
        <ImageButton
            android:id="@+id/btn_color_blue"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#0000FF"
            android:src="@android:drawable/presence_online"
            android:contentDescription="蓝色" />

        <Button
            android:id="@+id/btn_stroke_small"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="细"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_stroke_large"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="粗"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_undo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="撤销"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="清除"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>